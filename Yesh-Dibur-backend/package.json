{
  "name": "yesh-dibur-backend",
  "version": "1.0.0",
  "description": "Backend API for the Yesh Dibur platform",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "host": "cross-env HOST=0.0.0.0 node src/server.js",
    "test": "jest --runInBand"
  },
  "jest": {
    "setupFiles": [
      "dotenv/config"
    ],
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ]
  },
  "keywords": [
    "nodejs",
    "express",
    "postgresql",
    "redis",
    "rabbitmq",
    "firebase",
    "socket.io"
  ],
  "author": "Yesh Dibur Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "amqplib": "^0.10.4",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.2.0",
    "firebase-admin": "^12.1.0",
    "helmet": "^7.2.0",
    "http": "^0.0.1-security",
    "pg": "^8.11.5",
    "redis": "^4.6.7",
    "socket.io": "^4.8.3",
    "winston": "^3.13.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
